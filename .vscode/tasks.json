{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Lancer Make au démarrage",
            "type": "shell",
            "command": "make",
            "group": "none",
            "presentation": {
                "reveal": "always",    // Ouvre le terminal de force
                "panel": "new",       // Crée une nouvelle instance de terminal
                "focus": true,        // Met le curseur dedans
                "close": false        // NE PAS fermer le terminal après l'exécution
            },
            "runOptions": {
                "runOn": "folderOpen" // Se lance dès que VS Code ouvre le dossier
            }
        }
    ]
}